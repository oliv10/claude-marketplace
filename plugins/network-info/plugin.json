{
  "name": "network-info",
  "version": "1.0.4",
  "description": "Get network information including your public IP address, IP geolocation, and internet connectivity status",
  "author": {
    "name": "Community Marketplace",
    "email": "revi99@me.com"
  },
  "license": "MIT",
  "category": "utilities",
  "keywords": ["network", "ip", "geolocation", "connectivity", "api", "demo"],
  "homepage": "https://github.com/oliv10/claude-marketplace",
  "repository": "https://github.com/oliv10/claude-marketplace",
  "mcpServers": {
    "network-info-server": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/network-info-server/index.js"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}/mcp-servers/network-info-server"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "test -d \"${CLAUDE_PLUGIN_ROOT}/mcp-servers/network-info-server/node_modules\" || (cd \"${CLAUDE_PLUGIN_ROOT}/mcp-servers/network-info-server\" && npm install --silent)"
      }
    ]
  }
}
